# -------------------------------------------------------
# API 키 (사용하는 provider 것만 입력)
# -------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-key-here
GOOGLE_API_KEY=your-google-api-key-here

# -------------------------------------------------------
# 앱 설정 (선택 - 기본값 사용 가능)
# -------------------------------------------------------
APP__HOST=0.0.0.0
APP__PORT=8000
APP__RELOAD=false
APP__WORKERS=1

# -------------------------------------------------------
# 에이전트별 LLM 설정 (선택 - 기본값: gpt-4o-mini)
# provider는 모델 이름으로 자동 감지됨:
#   gemini-*        → Google Generative AI
#   gpt-* / o1-* 등 → OpenAI
#   그 외           → vLLM / SGLang (base_url 필수)
# -------------------------------------------------------
# 에이전트 필드: intake / supervisor / code_helper / text_helper

# OpenAI 사용 예시 (기본값)
# AGENTS__INTAKE__MODEL=gpt-4o-mini
# AGENTS__SUPERVISOR__MODEL=gpt-4o-mini
# AGENTS__CODE_HELPER__MODEL=gpt-4o-mini
# AGENTS__TEXT_HELPER__MODEL=gpt-4o-mini

# Google Gemini 사용 예시
# AGENTS__INTAKE__MODEL=gemini-2.0-flash
# AGENTS__SUPERVISOR__MODEL=gemini-2.0-flash
# AGENTS__CODE_HELPER__MODEL=gemini-2.0-flash
# AGENTS__TEXT_HELPER__MODEL=gemini-2.0-flash

# vLLM 사용 예시 (vllm serve <model> --port 8001 로 서버 기동)
# AGENTS__CODE_HELPER__MODEL=meta-llama/Llama-3.1-8B-Instruct
# AGENTS__CODE_HELPER__BASE_URL=http://localhost:8001/v1
# AGENTS__CODE_HELPER__API_KEY=EMPTY

# SGLang 사용 예시 (python -m sglang.launch_server --port 30000 로 서버 기동)
# AGENTS__CODE_HELPER__MODEL=meta-llama/Llama-3.1-8B-Instruct
# AGENTS__CODE_HELPER__BASE_URL=http://localhost:30000/v1
# AGENTS__CODE_HELPER__API_KEY=EMPTY
